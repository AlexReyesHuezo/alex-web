---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="hero">
  <div class="container hero-content">
    <div class="hero-text">
      <h1 class="hero-title">
        <span class="text-gradient">Alexander Reyes</span>
      </h1>
      <p class="hero-desc">
        {t("hero.desc")}
      </p>
      <div class="hero-actions">
        <a href="#projects" class="btn btn-primary">
          {t("nav.projects")}
        </a>
        <a href="#contact" class="btn btn-secondary"> {t("hero.contact")} </a>
      </div>
    </div>

    <div class="hero-image-container">
      <div class="hero-image-wrapper">
        <div class="hero-glow"></div>
        <img
          src="https://github.com/AlexReyesHuezo.png"
          alt="Alexander Reyes"
          class="hero-image"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-top: 5rem;
    overflow: hidden;
  }

  .hero-content {
    display: grid;
    gap: 3rem;
    align-items: center;
    position: relative;
    z-index: 10;
  }

  @media (min-width: 1024px) {
    .hero-content {
      grid-template-columns: 1fr 1fr;
    }

    .hero-text {
      order: 1;
    }

    .hero-image-container {
      order: 2;
    }
  }

  .hero-text {
    order: 2;
  }

  .hero-title {
    font-size: 3rem;
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }

  @media (min-width: 1024px) {
    .hero-title {
      font-size: 4.5rem;
    }
  }

  .hero-desc {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    max-width: 32rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    padding-top: 1rem;
  }

  .btn {
    padding: 0.75rem 1.5rem;
    border-radius: 9999px;
    font-weight: 500;
    transition: all 0.3s ease;
    display: inline-block;
  }

  .btn:hover {
    transform: scale(1.05);
  }

  .btn-primary {
    background-color: var(
      --color-primary-hover
    ); /* Using hover color as base for better contrast */
    color: white;
    box-shadow: 0 10px 15px -3px rgba(99, 102, 241, 0.25);
  }

  .btn-primary:hover {
    background-color: var(--color-primary);
  }

  .btn-secondary {
    border: 1px solid var(--color-border);
    color: white;
  }

  .btn-secondary:hover {
    background-color: var(--color-surface);
  }

  .hero-image-container {
    display: flex;
    justify-content: center;
    position: relative;
    order: 1;
  }

  .hero-image-wrapper {
    position: relative;
    width: 16rem;
    height: 16rem;
  }

  @media (min-width: 1024px) {
    .hero-image-wrapper {
      width: 24rem;
      height: 24rem;
    }
  }

  .hero-glow {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top right,
      var(--color-primary),
      var(--color-secondary)
    );
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.5;
    animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  @keyframes pulse {
    0%,
    100% {
      opacity: 0.5;
    }
    50% {
      opacity: 0.3;
    }
  }

  .hero-image {
    position: relative;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    border: 4px solid var(--color-border);
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
  }
</style>
