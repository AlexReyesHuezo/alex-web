                            </svg>
                        )}
                    </a>
                ))
            }
        </div>
    </div>
</section>

<style>
    .social-section {
        padding-top: 5rem;
        padding-bottom: 5rem;
        overflow: hidden;
    }

    .text-center {
        text-align: center;
    }

    .section-title {
        font-size: 2.25rem;
        font-weight: 700;
        margin-bottom: 3rem;
    }

    .social-links {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 2rem;
        position: relative;
    }

    .social-bubble {
        width: 6rem;
        height: 6rem;
        border-radius: 50%;
        background-color: var(--color-surface);
        border: 1px solid var(--color-border);
        display: flex;
        align-items: center;
        justify-content: center;
        color: rgba(255, 255, 255, 0.8);
        transition: all 0.3s ease;
    }

    .social-bubble:hover {
        transform: scale(1.1);
        border-color: transparent;
        color: white;
    }

    .social-bubble.linkedin:hover {
        background-color: #2563eb;
    }
    .social-bubble.github:hover {
        background-color: #1e293b;
    }
    .social-bubble.medium:hover {
        background-color: #000000;
    }
    .social-bubble.huggingface:hover {
        background-color: #eab308;
    }

    @keyframes float-up {
        0%,
        100% {
            transform: translateY(0);
        }
        50% {
            transform: translateY(-10px);
        }
    }
    @keyframes float-down {
        0%,
        100% {
            transform: translateY(0);
        }
        50% {
            transform: translateY(10px);
        }
    }
    .animate-float-up {
        animation: float-up 3s ease-in-out infinite;
    }
    .animate-float-down {
        animation: float-down 3s ease-in-out infinite;
    }
</style>
