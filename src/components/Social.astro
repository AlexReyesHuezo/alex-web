                            </svg>
                        )}
                        {social.icon === "huggingface" && (
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                role="img"
                                width="32"
                                height="32"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                            >
