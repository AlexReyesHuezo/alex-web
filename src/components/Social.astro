                                <path d="M9 18c-4.51 2-5-2-7-2" />
                            </svg>
                        )}
                        {social.icon === "medium" && (
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                role="img"
                                width="32"
                                height="32"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
